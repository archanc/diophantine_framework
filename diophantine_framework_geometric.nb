    "mMax", ",", "aSeq", ",", "getConvolutions", ",", "computeGrowth", ",", 
     "results1", ",", "results2"}], "]"}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
