 RowBox[{
  RowBox[{
   RowBox[{"mMax", "=", "100"}], ";"}], "   ", 
  RowBox[{"(*", 
   RowBox[{
   "Maximum", " ", "value", " ", "of", " ", "m", " ", "to", " ", "test"}], 
   "*)"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"2.", " ", "Define", " ", "the", " ", "bounded"}], ",", 
