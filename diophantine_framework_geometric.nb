  RowBox[{"(*", 
   RowBox[{"Degree", " ", "d"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"mMax", "=", "100"}], ";"}], "   ", 
  RowBox[{"(*", 
   RowBox[{
   "Maximum", " ", "value", " ", "of", " ", "m", " ", "to", " ", "test"}], 
   "*)"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"2.", " ", "Define", " ", "the", " ", "bounded"}], ",", 
