Notebook[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{"MaxMinorNorm", ",", "TestSequenceGrowth"}], "]"}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Function", " ", "to", " ", "compute", " ", "the", " ", "maximum", " ", 
     "minor", " ", "M_", "1", "k", " ", "for", " ", "given", " ", "d"}], ",", 
    "m", ",", 
    RowBox[{"and", " ", "sequence", " ", "a_k"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"MaxMinorNorm", "[", 
    RowBox[{"aSeq_", ",", "d_", ",", "m_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "Ddeg", ",", "aCoefs", ",", "poly", ",", "convCoefs", ",", "A", ",", 
       "Aprime", ",", "k", ",", "i", ",", "j", ",", "row", ",", "col", ",", 
       "minors"}], "}"}], ",", 
     RowBox[{
      RowBox[{"Ddeg", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"d", "+", "1"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{"m", "+", "1"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
        "Generate", " ", "sequence", " ", "up", " ", "to", " ", "Ddeg"}], "-",
         "2"}], "*)"}], 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
         RowBox[{"Note", ":", 
          RowBox[{
          "If", " ", "the", " ", "series", " ", "starts", " ", "at", " ", 
           "k"}]}], "=", "1"}], ",", 
        RowBox[{
         RowBox[{"aSeq", "[", "0", "]"}], " ", "should", " ", "evaluate", " ",
          "to", " ", "0"}]}], "*)"}], 
      RowBox[{"aCoefs", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"aSeq", "[", "n", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", "0", ",", 
           RowBox[{"Ddeg", "-", "2"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"poly", "=", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"aCoefs", "[", 
           RowBox[{"[", 
            RowBox[{"n", "+", "1"}], "]"}], "]"}], " ", 
          RowBox[{"x", "^", "n"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", "0", ",", 
           RowBox[{"Ddeg", "-", "2"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Compute", " ", "j"}], "-", 
        RowBox[{
        "fold", " ", "convolutions", " ", "of", " ", "a_k", " ", "using", " ",
          "polynomial", " ", "expansion"}]}], "*)"}], 
      RowBox[{"convCoefs", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"PadRight", "[", 
          RowBox[{
           RowBox[{"CoefficientList", "[", 
            RowBox[{
             RowBox[{"Series", "[", 
              RowBox[{
               RowBox[{"poly", "^", "idx"}], ",", 
               RowBox[{"{", 
                RowBox[{"x", ",", "0", ",", 
                 RowBox[{"Ddeg", "-", "2"}]}], "}"}]}], "]"}], ",", "x"}], 
            "]"}], ",", 
           RowBox[{"Ddeg", "-", "1"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"idx", ",", "0", ",", "d"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Construct", " ", "matrix", " ", "A", " ", "based", " ", "on", " ", 
        "Equation", " ", 
        RowBox[{"(", "11", ")"}], " ", "and", " ", 
        RowBox[{"(", "13", ")"}]}], "*)"}], 
      RowBox[{"A", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"i", "=", 
           RowBox[{"Quotient", "[", 
            RowBox[{"col", ",", 
             RowBox[{"m", "+", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"j", "=", 
           RowBox[{"Mod", "[", 
            RowBox[{"col", ",", 
             RowBox[{"m", "+", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"row", ">=", "j"}], ",", 
            RowBox[{"convCoefs", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"i", "+", "1"}], ",", 
               RowBox[{"row", "-", "j", "+", "1"}]}], "]"}], "]"}], ",", 
            "0"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"row", ",", "0", ",", 
           RowBox[{"Ddeg", "-", "2"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"col", ",", "0", ",", 
           RowBox[{"Ddeg", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"A", "'"}], " ", "is", " ", "A", " ", "with", " ", "the", " ",
         "first", " ", "column", " ", "removed", " ", 
        RowBox[{"(", 
         RowBox[{"p_", 
          RowBox[{"0", "^", 
           RowBox[{"(", "0", ")"}]}], " ", "removed"}], ")"}]}], "*)"}], 
      RowBox[{"Aprime", "=", 
       RowBox[{"A", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{"2", ";;"}]}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
        "Calculate", " ", "minors", " ", "M_", "1", "k", " ", "by", " ", 
         "removing", " ", "1", "st", " ", "row", " ", "and", " ", "k"}], "-", 
        RowBox[{"th", " ", "column", " ", "of", " ", "Aprime"}]}], "*)"}], 
      RowBox[{"minors", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"Det", "[", 
           RowBox[{"Drop", "[", 
            RowBox[{"Aprime", ",", 
             RowBox[{"{", "1", "}"}], ",", 
             RowBox[{"{", "k", "}"}]}], "]"}], "]"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", 
           RowBox[{"Ddeg", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Max", "[", "minors", "]"}]}]}], "]"}]}], "\[IndentingNewLine]",
   "\n", 
  RowBox[{"(*", 
   RowBox[{
   "Driver", " ", "function", " ", "to", " ", "test", " ", "the", " ", 
    "asymptotic", " ", "growth", " ", "rate", " ", 
    RowBox[{"(", "gamma", ")"}], " ", "over", " ", "a", " ", "range", " ", 
    "of", " ", "m"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TestSequenceGrowth", "[", 
   RowBox[{"aSeq_", ",", "d_", ",", "mMax_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"results", ",", "maxM", ",", "gammaEst"}], "}"}], ",", 
    RowBox[{
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Testing growth for d = \>\"", ",", "d"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<m \\t\\t  \[Gamma]^d \\t\\t \[Gamma]\>\"", "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", \
"\"\<----------------------------------------------------------\>\"", "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"results", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"maxM", "=", 
          RowBox[{"MaxMinorNorm", "[", 
           RowBox[{"aSeq", ",", "d", ",", "m"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"Estimate", " ", 
            RowBox[{"gamma", "^", "d"}], " ", "by", " ", "taking", " ", "the",
             " ", "m"}], "-", 
           RowBox[{
           "th", " ", "root", " ", "of", " ", "the", " ", "maximal", " ", 
            "minor"}]}], "*)"}], 
         RowBox[{"gammaEst", "=", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"maxM", ">", "0"}], ",", 
            RowBox[{"N", "[", 
             RowBox[{"maxM", "^", 
              RowBox[{"(", 
               RowBox[{"1", "/", "m"}], ")"}]}], "]"}], ",", "0"}], "]"}]}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
          "m", ",", "\"\< \\t\\t \>\"", ",", "gammaEst", 
           ",", "\"\< \\t\\t \>\"", ",", 
           RowBox[{"gammaEst", "^", 
            RowBox[{"(", 
             RowBox[{"1", "/", "d"}], ")"}]}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"m", ",", "maxM", ",", "gammaEst"}], "}"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"m", ",", "1", ",", "mMax"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "Plot", " ", "the", " ", "log", " ", "of", " ", "the", " ", "maximum", " ",
        "minor", " ", "to", " ", "visualize", " ", "linearity", " ", 
       RowBox[{"(", 
        RowBox[{"exponential", " ", "growth"}], ")"}]}], "*)"}], 
     RowBox[{"ListLogPlot", "[", 
      RowBox[{
       RowBox[{"results", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}], ",", 
       RowBox[{
       "PlotLabel", 
        "->", "\"\<Growth of \\!\\(\\*SubscriptBox[\\(M\\), \\(1, \
k\\)]\\)\>\""}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<m\>\"", 
          ",", "\"\<Log(\\!\\(\\*SubscriptBox[\\(M\\), \\(1, k\\)]\\))\>\""}],
          "}"}]}], ",", 
       RowBox[{"Joined", "->", "True"}], ",", 
       RowBox[{"Mesh", "->", "All"}]}], "]"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9854934774291363`*^9, 3.9854934908709564`*^9}},
