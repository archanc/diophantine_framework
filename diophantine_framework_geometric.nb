    "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Example", ":", 
    RowBox[{
     RowBox[{"The", " ", "Thue"}], "-", 
     RowBox[{"Morse", " ", "sequence"}]}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"aSeq", "[", "k_", "]"}], ":=", 
    RowBox[{"ThueMorse", "[", "k", "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Function", " ", "to", " ", "compute", " ", "the", " ", "j"}], "-", 
    RowBox[{"fold", " ", "convolutions", " ", 
     RowBox[{"a_k", "^", 
      RowBox[{"(", "j", ")"}]}]}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"getConvolutions", "[", 
     RowBox[{"dDegree_", ",", "maxK_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", ",", "poly"}], "}"}], ",", 
      RowBox[{
       RowBox[{"poly", "=", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"aSeq", "[", "k", "]"}], "*", 
           RowBox[{"x", "^", "k"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "0", ",", "maxK"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Use", " ", "Series"}], ",", 
         RowBox[{
         "convert", " ", "back", " ", "to", " ", "Normal", " ", "poly"}], ",", 
         RowBox[{
         "and", " ", "PadRight", " ", "to", " ", "prevent", " ", "index", " ",
           "errors"}]}], "*)"}], 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"PadRight", "[", 
          RowBox[{
           RowBox[{"CoefficientList", "[", 
            RowBox[{
             RowBox[{"Normal", "[", 
              RowBox[{"Series", "[", 
               RowBox[{
                RowBox[{"poly", "^", "j"}], ",", 
                RowBox[{"{", 
                 RowBox[{"x", ",", "0", ",", "maxK"}], "}"}]}], "]"}], "]"}], 
             ",", "x"}], "]"}], ",", 
           RowBox[{"maxK", "+", "1"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "0", ",", "dDegree"}], "}"}]}], "]"}]}]}], 
     "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"3.", " ", "Function", " ", "to", " ", "compute", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Log", "[", 
       RowBox[{"Max", "|", 
        RowBox[{"M_", "1", "k"}], "|"}], "]"}], ")"}], "/", "m"}], " ", "for",
     " ", "a", " ", "specific", " ", "m"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"computeGrowth", "[", 
     RowBox[{"dDegree_", ",", "m_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "Dval", ",", "maxK", ",", "aConv", ",", "matrixA", ",", "matrixAprime",
         ",", "minors", ",", "maxMinor"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{"D", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"d", "+", "1"}], ")"}], 
         RowBox[{"(", 
          RowBox[{"m", "+", "1"}], ")"}]}]}], "*)"}], 
      RowBox[{
       RowBox[{"Dval", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"dDegree", "+", "1"}], ")"}], "*", 
         RowBox[{"(", 
          RowBox[{"m", "+", "1"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
          RowBox[{
          "The", " ", "matrix", " ", "A", " ", "requires", " ", "equations", " ",
            "up", " ", "to", " ", "D"}], "-", "2"}], ",", 
         RowBox[{
         "requiring", " ", "indices", " ", "up", " ", "to", " ", "maxK"}]}], 
        "*)"}], 
       RowBox[{"maxK", "=", 
        RowBox[{"Dval", "-", "2"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Precompute", " ", "convolutions"}], "*)"}], 
       RowBox[{"aConv", "=", 
        RowBox[{"getConvolutions", "[", 
         RowBox[{"dDegree", ",", "maxK"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Construct", " ", "the", " ", 
         RowBox[{"(", 
          RowBox[{"D", "-", "1"}], ")"}], " ", "x", " ", "D", " ", "block", " ",
          "matrix", " ", "A"}], "*)"}], 
       RowBox[{"matrixA", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Flatten", "@", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"k", ">=", "j"}], ",", 
               RowBox[{"aConv", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"i", "+", "1"}], ",", 
                  RowBox[{"k", "-", "j", "+", "1"}]}], "]"}], "]"}], ",", 
               "0"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "0", ",", "dDegree"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "0", ",", "m"}], "}"}]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "0", ",", "maxK"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Construct", " ", 
         RowBox[{"A", "'"}], " ", "by", " ", "removing", " ", "the", " ", 
         "first", " ", "column"}], "*)"}], 
       RowBox[{"matrixAprime", "=", 
        RowBox[{"matrixA", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", 
           RowBox[{"2", ";;", "Dval"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "Compute", " ", "the", " ", "minors", " ", "M_", "1", "k", " ", "by",
           " ", "dropping", " ", "the", " ", "1", "st", " ", "row", " ", 
          "and", " ", "the", " ", "k"}], "-", 
         RowBox[{"th", " ", "column", " ", "of", " ", 
          RowBox[{"A", "'"}]}]}], "*)"}], 
       RowBox[{"minors", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Det", "[", 
           RowBox[{"Drop", "[", 
            RowBox[{"matrixAprime", ",", 
             RowBox[{"{", "1", "}"}], ",", 
             RowBox[{"{", "k", "}"}]}], "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", 
            RowBox[{"Dval", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Find", " ", "the", " ", "maximum", " ", "absolute", " ", "value", " ",
          "of", " ", "these", " ", "minors"}], "*)"}], 
       RowBox[{"maxMinor", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"Abs", "[", "minors", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Return", " ", "the", " ", "calculated", " ", "growth", " ", 
         "ratio"}], "*)"}], 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"maxMinor", "==", "0"}], ",", "0", ",", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"Log", "[", "maxMinor", "]"}], "/", "m"}], "]"}]}], 
        "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "4.", " ", "Execute", " ", "the", " ", "test", " ", "across", " ", "the", " ",
     "range", " ", "of", " ", "d", " ", "and", " ", "m", " ", "and", " ", 
