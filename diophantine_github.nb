 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Define", " ", "a_k"}], "=", 
     RowBox[{"mu", 
      RowBox[{
       RowBox[{"(", "k", ")"}], "^", "2"}]}]}], ",", 
